{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/auth/login",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "${IDENTITY_SERVICE_HOST}",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/api/identity/auth/login",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/auth/register",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "${IDENTITY_SERVICE_HOST}",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/api/identity/auth/register",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/auth/google-login",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "${IDENTITY_SERVICE_HOST}",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/api/identity/auth/google-login",
      "UpstreamHttpMethod": [ "POST", "OPTIONS" ]
    },
    {
      "DownstreamPathTemplate": "/api/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "${IDENTITY_SERVICE_HOST}",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/api/identity/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    },
    {
      "DownstreamPathTemplate": "/api/catalog/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "${CATALOG_SERVICE_HOST}",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/api/catalog/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    },
    {
      "DownstreamPathTemplate": "/api/{everything}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "${CIRCULATION_SERVICE_HOST}",
          "Port": 443
        }
      ],
      "UpstreamPathTemplate": "/api/circulation/{everything}",
      "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS" ],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer",
        "AllowedScopes": []
      }
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "${GATEWAY_BASE_URL}"
  }
}